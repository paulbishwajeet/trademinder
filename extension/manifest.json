{
  "manifest_version": 3,
  "name": "TradeMinder",
  "version": "1.0.0",
  "description": "Overlay TradeMinder data on E*TRADE portfolio page",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": [
    "https://*.etrade.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.etrade.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
