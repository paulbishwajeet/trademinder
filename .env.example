# Copy this file to .env and fill in real values.
#
# For local dev (venv):  DATABASE_URL points to localhost:5432
# For Docker Compose:    DATABASE_URL is set automatically — only set the vars below

# ── Required for Docker Compose (prod) ───────────────────────────────────────

# Strong random password for Postgres (used by docker-compose.prod.yml)
DB_PASSWORD=changeme-replace-with-strong-password

# Random secret for internal signing (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-replace-with-random-string

# ── Local dev only (venv) ─────────────────────────────────────────────────────

# Comment this out when using docker-compose (it sets DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://trademinder:password@localhost:5432/trademinder

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key for AI commentary (leave blank to disable)
ANTHROPIC_API_KEY=

# Host port the app is served on when using docker-compose.prod.yml (default: 3000)
FRONTEND_PORT=3000

# Scheduler / market hours (Eastern Time)
MARKET_HOURS_START=09:30
MARKET_HOURS_END=16:00
PRICE_REFRESH_INTERVAL_MINUTES=15
ALERT_ENGINE_INTERVAL_MINUTES=15
BRIEFING_GENERATE_TIME=08:00
