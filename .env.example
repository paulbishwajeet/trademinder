# Database — use localhost:5432 when running backend via venv locally
# Use db:5432 when backend runs inside Docker Compose
DATABASE_URL=postgresql+asyncpg://trademinder:password@localhost:5432/trademinder
SECRET_KEY=changeme-replace-with-random-string

# Anthropic (Phase 3 — leave blank for now)
ANTHROPIC_API_KEY=

# Optional scheduler config (Phase 2)
ALERT_ENGINE_INTERVAL_MINUTES=15
MARKET_HOURS_START=09:30
MARKET_HOURS_END=16:00
PRICE_REFRESH_INTERVAL_MINUTES=15
BRIEFING_GENERATE_TIME=08:00
